# AWS Credentials for Anthropic Claude on Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Optional: AWS Session Token (Bearer Token) for temporary credentials
# Use this if you're using STS temporary credentials or AssumeRole
AWS_SESSION_TOKEN=your_session_token_here
# Alternative name (same effect):
# AWS_BEDROCK_TOKEN=your_session_token_here

# Anthropic Model Configuration
ANTHROPIC_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# Alternative models:
# anthropic.claude-3-sonnet-20240229-v1:0
# anthropic.claude-3-haiku-20240307-v1:0
# anthropic.claude-3-opus-20240229-v1:0

# Server Configuration
PORT=3000
NODE_ENV=development
